model Classified {
    id Int @id @default(autoincrement())
    views Int @default(0)
    slug String @unique
    vrm String?
    title String?
    description String?
    year Int
    odoReading Int @default(0) @map("odo_reading")
    doors Int @default(2)
    seats Int @default(4)
    price Float @default(0)
    makeId Int @map("make_id")
    make Make @relation(fields: [makeId], references: [id])
    modelId Int @map("model_id")
    model Model @relation(fields: [modelId], references: [id])
    modelVariatId Int? @map("model_variat_id")
    modelVariant ModelVariant? @relation(fields: [modelVariatId], references: [id])
    ulezCompliance ULEZCompliance @default(EXEMPT)
    transmision Transmision @default(MANUAL)
    color Color @default(WHITE)
    fuelType FuelType @default(PETROL) @map("fuel_type")
    bodyType BodyType @default(HATCHBACK) @map("body_type")
    odoUnit OdoUnit @default(MILES) @map("odo_unit")
    currency Currency @default(PKR)
    status ClassifiedStatus @default(DRAFT)
    images Image[]
    customers   Customer[]

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([makeId, modelId], name: "index_make_model")
    @@index([status], name: "index_status")
    @@index([price], name: "index_price")

    @@map("classifieds")
}


enum OdoUnit {
    MILES
    KILOMETERS
}

enum ULEZCompliance {
    EXEMPT
    NON_EXEMPT
}

enum Transmision {
    MANUAL
    AUTOMATIC
}

enum Color {
    WHITE
    BLACK
    GREY
    SILVER
    RED
    BLUE
    GREEN
    YELLOW
    ORANGE
    BROWN
    PURPLE
}

enum FuelType {
    PETROL
    DIESEL
    ELECTRIC
    HYBRID
}

enum BodyType {
    HATCHBACK
    SEDAN
    SUV
    COUPE
    CONVERTIBLE
    WAGON
    VAN
    PICKUP
}

enum Currency {
    PKR
    USD
    EUR
    GBP
    JPY
    AUD
    CAD
    CHF
    CNY
    SEK
    NZD
}

enum ClassifiedStatus {
    DRAFT
    SOLD
    LIVE
}